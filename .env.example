# Actor Coach PWA — Environment Configuration
# Copy to .env.local for development

# === REQUIRED ===

# Session secret for signed cookies (min 32 chars)
SESSION_SECRET=change-me-in-production-minimum-32-chars!!

# === OPTIONAL ===

# OpenAI API key for browser-based analysis (must start with NEXT_PUBLIC_)
# NEXT_PUBLIC_OPENAI_API_KEY=sk-... (add when ready for real AI analysis)

# Node environment
NODE_ENV=development

# Server port
PORT=3000
