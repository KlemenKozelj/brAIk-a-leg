# Actor Coach PWA — Environment Configuration
# Copy to .env.local for development

# === REQUIRED ===

# Session secret for signed cookies (min 32 chars)
SESSION_SECRET=change-me-in-production-minimum-32-chars!!

# === OPTIONAL ===

# OpenAI API key (add when ready to use AI models)
OPENAI_API_KEY=

# Node environment
NODE_ENV=development

# Server port
PORT=3000
